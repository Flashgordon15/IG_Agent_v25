{
  "$schema": "./config_schema.json",
  "$extends": "config_v25.json",
  "version": "26.0.0",
  "_note": "v26 profitability overlay — merge with config_v25.json at load time (not yet wired in v25.6)",
  "capital_envelope": {
    "account_balance_gbp": 10000,
    "max_margin_pct": 0.20,
    "max_concurrent_risk_gbp": 1200,
    "max_daily_risk_deployed_gbp": 2500,
    "max_daily_loss_gbp": 500,
    "max_daily_profit_target_gbp": 1000,
    "min_available_gbp": 100,
    "reserve_pct": 0.10
  },
  "expectancy": {
    "min_trades_per_setup": 20,
    "ban_wr_below": 0.45,
    "probe_until_trades": 30,
    "active_wr_min": 0.52,
    "rolling_days": 14
  },
  "s2_momentum": {
    "default_min_range_pct": 0.0008,
    "epic_overrides": {}
  },
  "s4_ml_meta": {
    "enabled": true,
    "models_dir": "data_lake/models/s4",
    "min_decided_rows": 30,
    "min_val_wr": 0.52,
    "val_holdout_pct": 0.2
  },
  "ml_veto": {
    "enabled": true,
    "use_s4_models": true,
    "mode": "veto",
    "_note": "EUR/USD only — S4 veto-eligible after 6-bar label refresh (val WR 54.0%). Whitelist via per_epic.",
    "min_labelled_rows": 500,
    "min_probability": 0.58,
    "min_probability_high_conf": 0.55,
    "setup_specific_thresholds": true,
    "blend_fallback": false,
    "per_epic": {
      "CS.D.EURUSD.CFD.IP": {
        "enabled": true,
        "min_probability": 0.53
      }
    }
  },
  "shadow_service": {
    "enabled": true,
    "tail_poll_sec": 2.0,
    "snapshot_refresh_minutes": 60,
    "skip_in_pytest": true,
    "catch_up_on_start": true,
    "persist_offsets": true
  },
  "learning": {
    "label_horizon": "6bar"
  },
  "s1_rules": {
    "independent_enabled": true,
    "independent_threshold": 72
  },
  "portfolio_gate": {
    "enabled": true
  },
  "regime": {
    "calendar_enabled": true,
    "calendar_file": "config/calendar.json",
    "atr_percentile_block_above": 95,
    "same_direction_soft_cap": 3,
    "max_same_direction_risk_gbp": 400
  },
  "milestones": {
    "current": "M0",
    "daily_target_gbp": 0,
    "prove_days": 14,
    "targets": {
      "M1": 100,
      "M2": 250,
      "M3": 500,
      "M4": 1000
    }
  },
  "gate_relaxations": {
    "enabled": true,
    "fitness_min": 52,
    "epics": [
      "IX.D.DOW.IFM.IP",
      "IX.D.NASDAQ.IFM.IP"
    ],
    "require_points_healthy": true,
    "_note": "Approved 2026-06-08: 7d shadow near-miss on indices; fitness 55% blocked borderline scores"
  },
  "certification": {
    "l4_window_days": 14,
    "l4_median_daily_gbp": 100,
    "l4_min_profit_factor": 1.2,
    "l4_min_trading_days": 7,
    "l5_window_days": 14,
    "l5_days_required": 10,
    "l5_daily_target_gbp": 250
  }
}
