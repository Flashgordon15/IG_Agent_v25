<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.igagent.v25backup</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>__IG_AGENT_ROOT__/scripts/weekly_app_backup.sh</string>
	</array>
	<key>WorkingDirectory</key>
	<string>__IG_AGENT_ROOT__</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>IG_AGENT_ROOT</key>
		<string>__IG_AGENT_ROOT__</string>
	</dict>
	<key>StartCalendarInterval</key>
	<dict>
		<key>Weekday</key>
		<integer>0</integer>
		<key>Hour</key>
		<integer>7</integer>
		<key>Minute</key>
		<integer>0</integer>
	</dict>
	<key>StandardOutPath</key>
	<string>__IG_AGENT_ROOT__/src/data/logs/backup.log</string>
	<key>StandardErrorPath</key>
	<string>__IG_AGENT_ROOT__/src/data/logs/backup.log</string>
</dict>
</plist>
